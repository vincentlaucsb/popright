{
  "name": "popright",
  "version": "0.0.1",
  "description": "A tiny, typed, data-driven context menu primitive for modern web apps.",
  "type": "module",
  "homepage": "https://github.com/vincentlaucsb/popright#readme",
  "bugs": {
    "url": "https://github.com/vincentlaucsb/popright/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vincentlaucsb/popright.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "context-menu",
    "menu",
    "typescript",
    "headless-ui"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./styles.css",
    "./dropdown.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./dropdown.css": "./dist/dropdown.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../../scripts/build.mjs",
    "test": "vitest run --pool=threads"
  },
  "license": "MIT"
}
